{
  "name": "marten-docs-mcp",
  "version": "0.2.7",
  "private": true,
  "type": "module",
  "description": "Local MCP server for MartenDB docs retrieval and search",
  "scripts": {
    "clean": "rm -rf dist bundle test/*.js test/*.js.map",
    "dev": "bun run src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:dist:release": "tsc -p tsconfig.release.json",
    "build:bundle": "bun run scripts/bundle.ts",
    "build:bundle:debug": "bun run scripts/bundle.ts --sourcemap",
    "build:release": "bun run clean && bun run build:dist:release && bun run build:bundle",
    "start": "node dist/index.js",
    "test": "bun test",
    "smoke": "bun run scripts/smoke.ts",
    "doctor": "bun run scripts/doctor.ts",
    "perf:smoke": "bun run scripts/perf-smoke.ts",
    "migrate:sqlite": "bun run scripts/migrate-to-sqlite.ts",
    "install:local": "bun run scripts/install.ts",
    "uninstall:local": "bun run scripts/uninstall.ts",
    "upgrade:local": "bun run scripts/upgrade.ts",
    "verify:local": "bun run scripts/verify.ts",
    "eval": "bun run scripts/eval.ts",
    "eval:record": "bun run scripts/eval.ts --record",
    "eval:mine": "bun run scripts/mine-eval-from-telemetry.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.8.2",
    "@types/bun": "latest"
  }
}
